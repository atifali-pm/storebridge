# StoreBridge environment variables
# Copy to .env.local for local dev. Never commit .env.local.

# ---------- App ----------
NODE_ENV=development
APP_URL=http://localhost:3000

# ---------- Database ----------
# Matches docker-compose.yml credentials.
DATABASE_URL=postgres://storebridge:storebridge_dev_password@localhost:5436/storebridge

# ---------- Redis (BullMQ queue, Phase 3) ----------
REDIS_URL=redis://localhost:6390

# ---------- Shopify (Phase 2) ----------
# Get from Shopify Partner dashboard → Apps → <app> → App setup
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory
SHOPIFY_APP_URL=http://localhost:3000
# Shopify Admin API version (pin to latest stable — see https://shopify.dev/docs/api/usage/versioning)
SHOPIFY_API_VERSION=2025-01

# ---------- Better Auth (Phase 1/2) ----------
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---------- Token encryption (Phase 2) ----------
# 32-byte key, base64 encoded. Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ---------- Observability (Phase 4) ----------
SENTRY_DSN=
LOG_LEVEL=info
